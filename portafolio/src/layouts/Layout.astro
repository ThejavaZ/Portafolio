---
import ClientRouter  from "astro/components/ClientRouter.astro";
import "../styles/global.css";
import {Header} from "../components/layout/Header.tsx";
import Footer from "../components/layout/Footer.astro";

interface Layout {
  title: String;
  lang: String;
}

const { title, lang } = Astro.props as Layout;
const logo = "/logo.webp";
---

<!doctype html>
<html lang={lang ?? "es"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href={logo} />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? "Sin titulo"} - JavierSG</title>
    <meta name="author" content="JavierSG" />
    <meta name="description" content="Portafolio de JavierSG, programador y desarrollador web." />
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen bg-gray-100 md:grid md:grid-cols-layout md:grid-rows-layout dark:bg-gray-900 dark:text-white">
    <Header client:load />

    <main class="flex-1">
      <slot />
    </main>
    <!-- <Sidebar /> -->
    <Footer />
  </body>
</html>

<style is:global>
  html, body {
    height: 100%;
    font-family: "Fira Code", "Montserrat", sans-serif;
  }
  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100dvh;
  }
  
</style>
