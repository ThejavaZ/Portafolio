---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto | JavierSG">
  <section class="flex flex-col gap-12 py-12 px-6 max-w-5xl mx-auto">
    
    <div class="text-center space-y-4">
      <h2 class="text-5xl font-black italic uppercase tracking-tighter text-white">
        ¿Hablamos de <span class="text-blue-500 underline decoration-blue-500/30">Backend</span>?
      </h2>
      <p class="text-gray-400 font-medium">Envíame un mensaje o búscame en mis redes sociales.</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      
      <form
        name="contacto"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="bg-gray-800/20 p-8 rounded-[2.5rem] border border-white/5 backdrop-blur-xl shadow-2xl flex flex-col gap-6"
      >
        <input type="hidden" name="form-name" value="contacto" />
        <p class="hidden">
          <label>No llenes este campo: <input name="bot-field" /></label>
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="name" class="text-xs uppercase tracking-widest font-bold text-blue-500 ml-2">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Ej. John Doe"
              class="bg-gray-900/50 border border-white/10 rounded-2xl p-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-xs uppercase tracking-widest font-bold text-blue-500 ml-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="bg-gray-900/50 border border-white/10 rounded-2xl p-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="subject" class="text-xs uppercase tracking-widest font-bold text-blue-500 ml-2">Asunto</label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            placeholder="¿En qué puedo ayudarte?"
            class="bg-gray-900/50 border border-white/10 rounded-2xl p-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="text-xs uppercase tracking-widest font-bold text-blue-500 ml-2">Mensaje</label>
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            placeholder="Escribe tu propuesta aquí..."
            class="bg-gray-900/50 border border-white/10 rounded-2xl p-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all resize-none"
          ></textarea>
        </div>

        <button 
          type="submit" 
          class="bg-blue-600 hover:bg-blue-500 text-white font-black uppercase italic py-4 rounded-2xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 flex justify-center items-center gap-2 group"
        >
          Enviar Mensaje
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5 group-hover:translate-x-1 transition-transform">
            <path d="M5 12h14m-7-7l7 7-7 7" />
          </svg>
        </button>
      </form>

      <div class="flex flex-col gap-8">
        
        <div class="grid grid-cols-3 gap-4">
          <a href="https://github.com/ThejavaZ" class="group flex flex-col items-center gap-3 bg-gray-800/40 p-6 rounded-[2rem] border border-white/5 hover:border-blue-500/50 transition-all duration-300">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-gray-400 group-hover:text-white transition-colors duration-300">
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path>
            </svg>
            <span class="text-[10px] font-bold uppercase tracking-tighter text-gray-500 group-hover:text-gray-300 transition-colors">GitHub</span>
          </a>

          <a href="https://www.linkedin.com/in/javier-armando-sarmiento-gil-aa10b0249/" class="group flex flex-col items-center gap-3 bg-gray-800/40 p-6 rounded-[2rem] border border-white/5 hover:border-blue-500/50 transition-all duration-300">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-gray-400 group-hover:text-blue-400 transition-colors duration-300">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            <span class="text-[10px] font-bold uppercase tracking-tighter text-gray-500 group-hover:text-gray-300 transition-colors">LinkedIn</span>
          </a>

          <a href="mailto:jsdash10000@gmail.com" class="group flex flex-col items-center gap-3 bg-gray-800/40 p-6 rounded-[2rem] border border-white/5 hover:border-red-500/50 transition-all duration-300">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-gray-400 group-hover:text-red-500 transition-colors duration-300">
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
              <path d="M3 7l9 6l9 -6"></path>
            </svg>
            <span class="text-[10px] font-bold uppercase tracking-tighter text-gray-500 group-hover:text-gray-300 transition-colors">Email</span>
          </a>
        </div>

        <div class="relative group h-full">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-blue-900 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
            <div class="relative bg-gray-900 rounded-[2rem] overflow-hidden border border-white/10 h-full min-h-[250px]">
                <div class="absolute top-4 left-4 z-10 bg-gray-900/80 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 text-[10px] font-bold uppercase tracking-widest text-white">
                    Ubicación: Hermosillo, México
                </div>
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d111516.34005086815!2d-111.0289893081123!3d29.088914652253337!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86ce836f6630f57d%3A0x600b33230a133f92!2sHermosillo%2C%20Son.!5e0!3m2!1ses-419!2smx!4v1700000000000!5m2!1ses-419!2smx"
                  class="w-full h-full grayscale invert contrast-125 border-none"
                  allowfullscreen=""
                  loading="lazy"
                ></iframe>
            </div>
        </div>

      </div>
    </div>
  </section>
</Layout>