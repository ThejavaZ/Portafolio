---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { allTechs } from "../../data/tech-data"; // Importas tus datos

export function getStaticPaths() {
  return allTechs.map((tech) => ({
    params: { technology: tech.id },
    props: { tech },
  }));
}

const { tech } = Astro.props;
---

<Layout title={tech.name}>
  <header class={`${tech.theme} py-12 flex flex-col md:flex-row items-center justify-center gap-6 border-b border-white/10 shadow-2xl`}>
    <Image 
      transition:name={`${tech.id}-tech`} 
      src={tech.logo} 
      alt={tech.name} 
      width={120} 
      height={120} 
      class="drop-shadow-[0_0_15px_rgba(255,255,255,0.3)]"
    />
    <h1 class="text-5xl md:text-6xl font-black text-white tracking-tighter italic uppercase">{tech.name}</h1>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-center text-gray-500 font-bold uppercase tracking-[0.3em] mb-12 text-sm">Tech Stack & Ecosystem</h2>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {tech.stack.map((item) => (
        <div class="group bg-gray-900/40 border border-white/5 p-6 rounded-3xl flex flex-col items-center transition-all duration-500 hover:bg-gray-800 hover:border-blue-500/30 hover:-translate-y-2 shadow-xl">
          <div class="bg-gray-950 p-5 rounded-2xl mb-5 shadow-inner group-hover:scale-110 transition-transform duration-300">
            <Image 
              src={`/technologies/${item.img}`} 
              alt={item.name} 
              class="w-14 h-14 object-contain"
            />
          </div>
          <h3 class="font-bold text-lg text-white mb-1">{item.name}</h3>
          <span class="text-[10px] font-black text-blue-500 uppercase tracking-widest bg-blue-500/10 px-3 py-1 rounded-full">
            {item.type}
          </span>
        </div>
      ))}
    </div>

    <div class="mt-20 flex justify-center">
      <a href="/about" class="group flex items-center gap-3 text-gray-400 hover:text-white transition-colors font-bold uppercase text-xs tracking-widest">
        <span class="transition-transform group-hover:-translate-x-2">←</span> 
        Volver a especialidades
      </a>
    </div>
  </main>
</Layout>