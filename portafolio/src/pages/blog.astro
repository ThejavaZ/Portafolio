---
import Layout from "../layouts/Layout.astro";
import { allPosts } from "../data/blog-data";
---

<Layout title="Mi Bitácora Tech">
  <main class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-black mb-12 text-center bg-gradient-to-r from-blue-500 to-green-500 bg-clip-text text-transparent italic uppercase">
        Bitácora de Desarrollo
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allPosts.map((post) => (
        <article class="bg-gray-900/50 border border-white/10 rounded-3xl overflow-hidden hover:border-blue-500/50 transition-all group">
          <div class="p-6">
            <span class="text-xs font-bold uppercase tracking-widest text-blue-400">{post.category}</span>
            <h2 class="text-2xl font-bold my-3 group-hover:text-white transition-colors">{post.title}</h2>
            <p class="text-gray-400 text-sm mb-5">{post.excerpt}</p>
            <div class="flex justify-between items-center">
                <span class="text-xs text-gray-500">{post.date}</span>
                <a href={`/blog/${post.id}`} class="text-white font-bold text-sm hover:underline">Leer más →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>